# Copy to .env.local and fill in. .env.local is gitignored.

# Magic publishable key (client-side, safe to expose in the bundle).
# Get it from https://dashboard.magic.link → your app → Publishable API Key.
# Use the pk_test_ key in development. When unset, the app falls back to mock login.
# Dashboard: enable Google social login and allow http://localhost:3000/callback as a redirect URL.
NEXT_PUBLIC_MAGIC_API_KEY=

# Particle Universal Accounts (client-side credentials) from
# https://dashboard.particle.network → project → web app.
# All three must be set for the real cross-chain balance/transfers;
# when unset, those features stay dormant and the mock flow still works.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Web Push (optional — "link claimed" notifications).
# Generate a keypair with: npx web-push generate-vapid-keys
# The public key ships to the client; the PRIVATE key is server-only (used by
# /api/push) and must also be set in your Vercel project env for production.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
