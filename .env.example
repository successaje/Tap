# Copy to .env.local and fill in. .env.local is gitignored.

# Public site origin (used to build absolute link-preview image URLs).
# Defaults to https://tap-xyz.vercel.app if unset — override for a fork or
# a different deployment domain.
NEXT_PUBLIC_SITE_URL=

# Magic publishable key (client-side, safe to expose in the bundle).
# Get it from https://dashboard.magic.link → your app → Publishable API Key.
# Use the pk_test_ key in development. When unset, the app falls back to mock login.
# Dashboard: enable Google social login and allow http://localhost:3000/callback as a redirect URL.
NEXT_PUBLIC_MAGIC_API_KEY=

# Particle Universal Accounts (client-side credentials) from
# https://dashboard.particle.network → project → web app.
# All three must be set for the real cross-chain balance/transfers;
# when unset, those features stay dormant and the mock flow still works.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Web Push (optional — "link claimed" notifications).
# Generate a keypair with: npx web-push generate-vapid-keys
# The public key ships to the client; the PRIVATE key is server-only (used by
# /api/push) and must also be set in your Vercel project env for production.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Upstash Redis (optional — persists push subscriptions + the list of
# outstanding links the background watcher checks). One free account at
# https://console.upstash.com → Redis → Create Database → REST API section
# has both values below. Without these, push still works but only fires
# while a tab is open (same behavior as before this was added).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (optional — schedules the background watcher itself).
# Same Upstash account → QStash tab → "Signing Keys" has both values below.
# After deploying, also create ONE schedule in the QStash console:
#   Destination: https://<your-domain>/api/cron/check-claims
#   Cron:        */2 * * * *   (every 2 minutes; free tier allows 1,000/day)
# QStash calls that URL on schedule; these keys let the route verify the
# call genuinely came from QStash and not an arbitrary caller.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
